NODE_ENV=production
AUTH_SECRET=superscretchangeitplz
# Generate your own master key by running: python3 -c "import os, base64; key = os.urandom(32); print('base64:' + base64.b64encode(key).decode('utf-8'))" 
MASTER_VAULT_KEY_V1=base64:qnHTmwYb+uoygIw9MsRMY22vS5YPchY+QOi/E79GAvM=
NEO4J_URI_BOLT=bolt://neo4j:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=password
# Dev only (vite dev server / docker-compose.yml). Production images use
# same-origin relative URLs proxied by nginx — leave unset for docker-compose.prod.yml.
VITE_API_URL=http://localhost:5001
# Comma-separated CORS allowed origins. Defaults to http://localhost:5173 (Vite dev) when unset.
ALLOWED_ORIGINS=http://localhost:5173
DATABASE_URL=postgresql://flowsint:flowsint@localhost:5433/flowsint
REDIS_URL=redis://redis:6379/0
# FinSkalp / compliance (local only — do not commit real keys)
TRONGRID_API_KEY=
# Sovereign TRON FullNode (java-tron) — Phase 2
# failover | trongrid | sovereign
FINSKALP_TRON_PROVIDER=failover
FINSKALP_TRON_SOVEREIGN_URL=http://127.0.0.1:8090
FINSKALP_TRON_SNAPSHOT_MIN_HEIGHT=70000000
# Solana JSON-RPC (public endpoint is rate-limited)
FINSKALP_SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
# Optional self-hosted Blockscout (docker/docker-compose.blockscout.yml --profile blockscout)
# BLOCKSCOUT_ETHEREUM_RPC_URL=http://host.docker.internal:8545
# BLOCKSCOUT_HOST_PORT=4000
# FINSKALP_BLOCKSCOUT_ETH_URL=http://localhost:4000/api
# Combat mode (COMPLIANCE_COMBAT_MODE=1) defaults entity_labels to postgres.
# Set memory explicitly for offline dev without DATABASE_URL.
FINSKALP_ENTITY_STORE=postgres
# Fusion pipeline mode: rfc0003 (default) uses mandatory IngestPipeline path
FINSKALP_FUSION_MODE=rfc0003
COMPLIANCE_COMBAT_MODE=1
# FinSkalp OSINT investigate (seconds); frontend abort = this + 15s
COMPLIANCE_INVESTIGATE_TIMEOUT_SEC=300
# Live KYT watchlist (comma-separated TRON/ETH/BTC addresses)
FINSKALP_KYT_WATCHLIST=
# Etherscan / BscScan (multi-hop ETH/BSC fusion)
ETHERSCAN_API_KEY=
BSCSCAN_API_KEY=
# Blockscout (Etherscan-compatible) — defaults to public blockscout.com
FINSKALP_BLOCKSCOUT_ETH_URL=https://eth.blockscout.com/api
FINSKALP_BLOCKSCOUT_BSC_URL=https://bsc.blockscout.com/api
FINSKALP_BLOCKSCOUT_POLYGON_URL=https://polygon.blockscout.com/api
POLYGONSCAN_API_KEY=
# Optional seed address for live STR + default watchlist entry
FINSKALP_COMBAT_SEED_ADDRESS=
FINSKALP_COMBAT_SEED_CHAIN=tron
# --- FinSkalp production hardening (optional self-hosted stack) ---
# SECURITY: standalone only — docker compose -f docker-compose.hardening.yml up -d
# Do NOT merge with docker-compose.prod.yml (restarts prod containers).
FLOWSINT_DOCKER_NETWORK=flowsint_network_prod
FLOWSINT_POSTGRES_HOST=flowsint-postgres-prod
GRAFANA_HOST_PORT=3001
OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4317
OTEL_SERVICE_NAME=finskalp-api
MEILI_URL=http://localhost:7700
MEILI_MASTER_KEY=finskalp-dev-key
UNLEASH_URL=http://localhost:4242/api
UNLEASH_API_TOKEN=development.unleash-insecure-api-token
UNLEASH_APP_NAME=finskalp-compliance
# Comma-separated risk flags when Unleash unavailable: cospend_v2,illegal_flow_detector_v2
FINSKALP_FEATURE_FLAGS=
# Eval deploy gate override: pass | block (or rely on last eval report)
FINSKALP_EVAL_GATE=
FINSKALP_EVAL_MIN_PRECISION=0.7
FINSKALP_EVAL_MIN_RECALL=0.6
FINSKALP_EVAL_REPORT_DIR=reports/attribution_eval
# Optional: require Bearer token on investigate / OSINT feedback (recommended for LAN exposure)
FINSKALP_DEMO_API_TOKEN=
# Skip Unleash client when using FINSKALP_FEATURE_FLAGS env fallback
UNLEASH_DISABLED=1
FINSKALP_IDEMPOTENCY_TTL_SEC=86400
FINSKALP_FUSION_LOCK_TTL_SEC=180
GRAFANA_ADMIN_PASSWORD=finskalp
