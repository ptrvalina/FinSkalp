<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="utf-8"/>
  <title>{{ report.report_id }}</title>
  <style>
    body { font-family: "Segoe UI", Arial, sans-serif; margin: 2rem; color: #111; }
    h1 { font-size: 1.35rem; }
    .meta { color: #555; font-size: 0.9rem; margin-bottom: 1.5rem; }
    .badge { display: inline-block; padding: 0.2rem 0.6rem; border-radius: 4px;
             background: #1e3a5f; color: #fff; font-size: 0.8rem; }
    section { margin: 1.25rem 0; }
    h2 { font-size: 1rem; border-bottom: 1px solid #ddd; padding-bottom: 0.3rem; }
    table { width: 100%; border-collapse: collapse; font-size: 0.9rem; }
    td, th { border: 1px solid #ddd; padding: 0.45rem 0.6rem; vertical-align: top; }
    th { background: #f4f6f8; text-align: left; }
    .score { font-size: 1.4rem; font-weight: 700; }
  </style>
</head>
<body>
  <h1>{{ report.report_type_ru }}</h1>
  <div class="meta">
    <span class="badge">{{ report.classification_ru }}</span>
    ID: {{ report.report_id }} · Кейс: {{ report.case_ref }} · {{ report.generated_at }}
  </div>
  <section>
    <h2>Резюме</h2>
    <p>{{ report.executive_summary_ru }}</p>
    <p class="score">Индекс риска: {{ report.illegal_flow_score }}/100 ({{ report.risk_level }})</p>
  </section>
  <section>
    <h2>Типология</h2>
    <table>
      <tr><th>Код</th><td>{{ report.typology_code }}</td></tr>
      <tr><th>Наименование</th><td>{{ report.typology_name_ru }}</td></tr>
      <tr><th>Банк</th><td>{{ report.bank_name or "—" }}</td></tr>
      <tr><th>Сумма</th><td>{{ report.operation_amount or "—" }}</td></tr>
    </table>
  </section>
  <section>
    <h2>Правовые основания</h2>
    <ul>{% for item in report.legal_basis_ru %}<li>{{ item }}</li>{% endfor %}</ul>
  </section>
  <section>
    <h2>Решение</h2>
    <p><strong>{{ report.decision_ru }}</strong></p>
    <p>{{ report.decision_basis_ru }}</p>
  </section>
</body>
</html>
