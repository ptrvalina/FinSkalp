<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="utf-8"/>
  <title>Отчёт {{ report.case_ref }}</title>
  <style>
    body { font-family: Arial, sans-serif; margin: 2rem; }
    h1 { font-size: 1.3rem; }
    .score { font-size: 1.5rem; font-weight: bold; }
    table { border-collapse: collapse; width: 100%; margin-top: 1rem; }
    td, th { border: 1px solid #ccc; padding: 0.4rem 0.6rem; }
  </style>
</head>
<body>
  <h1>{{ report.scenario_title_ru }}</h1>
  <p>Кейс: {{ report.case_ref }}</p>
  <p class="score">Индекс: {{ report.illegal_flow_score }}/100 ({{ report.risk_level }})</p>
  <p>{{ report.executive_summary_ru }}</p>
  {% if xgb %}
  <h2>XGBoost ({{ xgb.model_version }})</h2>
  <table>
    <tr><th>Эвристика</th><td>{{ risk_scoring.heuristic_score }}</td></tr>
    <tr><th>Модель</th><td>{{ xgb.model_score }}</td></tr>
    <tr><th>Итог</th><td>{{ xgb.blended_score }}</td></tr>
  </table>
  {% endif %}
  <h2>Индикаторы</h2>
  <ul>
  {% for f in report.findings %}
    <li>[{{ f.severity|upper }}] {{ f.title_ru }}</li>
  {% endfor %}
  </ul>
</body>
</html>
