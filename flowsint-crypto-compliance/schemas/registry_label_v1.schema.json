{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://flowsint.io/schemas/regulator-hub/v1/registry-label.json",
  "title": "SovereignRiskLabel",
  "description": "Запись суверенного реестра риск-меток РФ/СНГ (перечень 115-ФЗ, ФИУ, внутренняя OSINT-разведка)",
  "type": "object",
  "required": ["chain", "address", "source"],
  "additionalProperties": false,
  "properties": {
    "label_id": { "type": "string" },
    "source": {
      "type": "string",
      "enum": [
        "rosfinmonitoring",
        "cbr",
        "fiu",
        "mvd",
        "bank_hub",
        "control_purchase",
        "internal_osint",
        "cis_partner",
        "other"
      ]
    },
    "chain": { "type": "string", "enum": ["btc", "eth", "tron"] },
    "address": { "type": "string", "minLength": 26 },
    "entity_name": { "type": "string" },
    "category": { "type": "string" },
    "risk_score": { "type": "number", "minimum": 0, "maximum": 100 },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "sanctioned": { "type": "boolean", "default": false },
    "list_reference": { "type": "string" },
    "disputed": { "type": "boolean", "default": false },
    "snapshot_at": { "type": "string", "format": "date-time" },
    "cluster_ref": { "type": "string" }
  }
}
